# --- Targets ---
# Provide either a full URL or the discrete components below.
# In Porter, inject these from the linked datastore add-on.
POSTGRES_URL=postgresql://user:pass@host:5432/dbname
# Optional discrete vars (used only if POSTGRES_URL is empty):
# PG_HOST=
# PG_PORT=5432
# PG_USER=
# PG_PASSWORD=
# PG_DATABASE=
# PG_SSLMODE=require

REDIS_URL=redis://:password@host:6379/0
# Optional discrete vars (used only if REDIS_URL is empty):
# REDIS_HOST=
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
# REDIS_TLS=false

# --- Safety caps (defaults are conservative) ---
MAX_JOB_DURATION_SEC=600        # auto-stop after this many seconds
MAX_WORKERS_PER_JOB=50
MAX_CONNECTIONS_PER_JOB=200
MAX_CONCURRENT_JOBS=5
ALLOW_DISK_WORKLOADS=true       # set false to disable destructive disk tests
