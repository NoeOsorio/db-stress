# --- Postgres target ---
# Pick ONE of the two forms below.
#
# Form A: full URL (preferred for local dev)
DB_URL=postgresql://user:pass@host:5432/dbname

# Form B: discrete components (used when DB_URL is empty).
# These names match what Porter's RDS / Aurora datastore add-on injects.
# DB_HOST=
# DB_PORT=5432
# DB_USER=
# DB_PASS=
# DB_NAME=
# DB_SSLMODE=require            # set to 'require' for RDS / Aurora

# Legacy names (POSTGRES_URL, PG_HOST, PG_USER, PG_PASSWORD, PG_DATABASE,
# PG_SSLMODE) are still accepted if you already have them set somewhere.

# --- Redis target ---
# Pick ONE of the two forms below.

# Form A: full URL
REDIS_URL=redis://:password@host:6379/0

# Form B: discrete components — matches Porter's ElastiCache add-on.
# REDIS_HOST=
# REDIS_PORT=6379
# REDIS_PASS=
# REDIS_DB=0
# REDIS_TLS=false               # set true to use rediss:// (TLS)

# --- Safety caps (defaults are conservative) ---
MAX_JOB_DURATION_SEC=600        # every job auto-terminates after this
MAX_WORKERS_PER_JOB=50
MAX_CONNECTIONS_PER_JOB=200
MAX_CONCURRENT_JOBS=5
ALLOW_DISK_WORKLOADS=true       # set false to disable destructive disk tests
